PORT=3000
DB_HOST=localhost
# Default 5433 matches `npm run dev:db` (host 5433 -> container 5432). Use 5432 for a local Postgres on the default port.
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=bithack
# Optional: milliseconds before giving up when DB is unreachable (default 10000)
# DB_CONNECTION_TIMEOUT_MS=10000
JWT_SECRET=change-me
